<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Splintered Axe 3D</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="style.css">
</head>

<body>

<header>
  <nav>
    <h1>Splintered Axe 3D</h1>
    <div class="nav-links">
      <a href="#services">Services</a>
      <a href="#gallery">Gallery</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>
</header>

<section class="hero">
  <h2>Bring Your Ideas to Life</h2>
  <p>Professional 3D Printing & Prototyping Services</p>
  <a href="#contact" class="button">Request a Quote</a>
</section>

<section id="services" class="section">
  <h2>Our Services</h2>
  <div class="cards">
    <div class="card">
      <h3>FDM Printing</h3>
      <p>Affordable and fast printing using PLA, and PETG.</p>
    </div>
  </div>
</section>

<section id="gallery" class="section dark">
  <h2>Recent Projects</h2>
  <div class="gallery">
    <img src="https://images.unsplash.com/photo-1581093458791-9f3c3900df5b">
    <img src="https://images.unsplash.com/photo-1581092160612-7c4d2f4e8f7b">
    <img src="https://images.unsplash.com/photo-1581090700227-1e37b190418e">
    <img src="https://images.unsplash.com/photo-1581093450025-4c8d2df0d7c5">
  </div>
</section>

<section id="contact" class="section">
  <h2>Request a Quote</h2>
  <p>Upload your files and send project details below.</p>

  <!-- FORM SPREE FORM -->
  <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" enctype="multipart/form-data">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="email" name="email" placeholder="Email Address" required>
    <textarea name="message" placeholder="Describe your project" required></textarea>
    <input type="file" name="file">
    <button type="submit">Send Request</button>
  </form>
</section>

<footer>
  <p>© 2026 Splintered Axe</p>
</footer>

</body>
</html>
